{
  "name": "joust-neon-edition",
  "version": "1.0.0",
  "description": "Single-file web Joust with neon effects, power-ups, and a flat-file high score table",
  "main": "joust.js",
  "bin": "joust.js",
  "scripts": {
    "start": "node joust.js",
    "build": "pkg . --no-bytecode --public --compress GZip --out-path dist"
  },
  "pkg": {
    "targets": [
      "node22-macos-arm64",
      "node22-macos-x64",
      "node22-win-x64",
      "node22-win-arm64",
      "node22-linux-x64"
    ],
    "outputPath": "dist"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.3.0"
  }
}
