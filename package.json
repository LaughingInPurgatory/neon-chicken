{
  "name": "joust-neon-edition",
  "version": "2.1.0",
  "description": "A neon remake of the arcade classic Joust — a self-contained Electron desktop app with procedural graphics, synthesized sound, power-ups, and a flat-file high score table",
  "author": "schtufbox",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "app": "electron .",
    "dist": "electron-builder",
    "test": "node test/scores.test.js"
  },
  "build": {
    "appId": "com.schtufbox.joust",
    "productName": "JOUST Neon Edition",
    "artifactName": "joust-neon-edition-${os}-${arch}.${ext}",
    "afterPack": "./build/afterPack.js",
    "files": [
      "main.js",
      "preload.js",
      "scores.js",
      "renderer/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.games",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "category": "Game",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
